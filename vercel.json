{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd client && npm run build",
  "installCommand": "cd client && npm install",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "redirects": [
    {
      "source": "/contact.html",
      "destination": "/info/contact",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "srikamalahospital.store" }],
      "destination": "https://srikamalahospital.online/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.srikamalahospital.store" }],
      "destination": "https://srikamalahospital.online/:path*",
      "permanent": true
    }
  ]
}
